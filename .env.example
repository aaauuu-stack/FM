# =============================================================================
# Copia questo file in .env e compila i valori
# Guida completa: docs/API_SETUP.md
# =============================================================================

# --- The Odds API (gratis: 500 crediti/mese) ---
# Registrati su: https://the-odds-api.com/
ODDS_API_KEY=

# Regione bookmaker (eu consigliata per il Mondiale)
ODDS_REGION=eu
ODDS_SPORT=soccer_fifa_world_cup

# --- OddsPapi (correct score FT + 1T, ~250 req/mese free) ---
# Registrati su: https://oddspapi.io/
ODDSPAPI_API_KEY=

# --- OpenAI Vision (lettura screenshot FM — come ChatGPT) ---
# Registrati su: https://platform.openai.com/
# Modello default: gpt-4o-mini (~$0.01 per analisi con 2-3 screenshot)
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o-mini
